# --- Youtube Configuration ---
# Your Google Cloud Console API Key
YOUTUBE_API_KEY=your_dev_api_key_here
# The ID of the YouTube Live Stream (found in the URL)
YOUTUBE_STREAM_ID=copy_stream_id_here

# --- Server Configuration ---
# Port the internal server will listen on (e.g., 8080)
SERVER_PORT=8080

# --- TTS (Text-to-Speech) Configuration ---
# If enabled, chat messages will be read aloud by the system
TTS_ENABLED=true
# The name of the voice assistant installed on your OS
# MacOS (en): Fred | MacOS (ru): Milena | Windows: David, Hazel
TTS_NAME=Milena

# --- Alerts Configuration ---
# Enable or disable alert triggers
ALERTS_ENABLED=true
# The single character prefix used to trigger commands (e.g., @ or !)
ALERTS_TOKEN=@
# Absolute path to the directory containing your media files
ALERTS_MEDIA_PATH=/home/user/memes
# Path to the YAML file defining alert commands
ALERTS_COMMANDS_FILE_PATH=/home/user/memes/commands.yaml

# --- Webhook Configuration ---
# Enable or disable outgoing webhooks for chat events
WEBHOOK_ENABLED=false